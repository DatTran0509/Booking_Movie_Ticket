# Public URL of the frontend. Use your domain or ALB DNS name.
CLIENT_URL=https://app.example.com

# Keep this empty when the frontend container proxies /api to the backend on the same host.
VITE_BASE_URL=
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxx
VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/original
VITE_CURRENCY=$

# Backend
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net
MONGODB_DB_NAME=quickshow
CLERK_SECRET_KEY=sk_live_xxxxx
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_CURRENCY=usd
PAYMENT_HOLD_MINUTES=10
TMDB_API_KEY=tmdb_bearer_token
INNGEST_EVENT_KEY=inngest_event_key

# Mail
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SENDER_EMAIL=no-reply@example.com

# CORS
CORS_ALLOWED_ORIGINS=https://app.example.com
